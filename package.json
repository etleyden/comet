{
  "name": "web-template",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "shared"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev": "docker compose --profile dev up --build",
    "dev:down": "docker compose --profile dev down",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "prod": "docker compose --profile prod up --build -d",
    "prod:down": "docker compose --profile prod down",
    "start:backend": "npm --prefix backend run start",
    "clean": "docker system prune --all -f && docker volume prune --all -f",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "test": "npm --workspaces run test --if-present",
    "test:unit": "npm run test:unit --workspaces --if-present",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "coverage:view": "http-server reports -p 2999 -o -c-1"
  },
  "dependencies": {
    "@fontsource/roboto": "^5.2.9"
  },
  "devDependencies": {
    "http-server": "^14.1.1",
    "prettier": "^3.8.1",
    "vitest": "^4.0.18"
  }
}