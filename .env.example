# ── Environment ──────────────────────────────────────────────
NODE_ENV=development          # optional  | "production" for deployment

# ── Database (REQUIRED) ───────────────────────────────────────
# The app will refuse to start if any of these are missing.
DB_HOST=                      # required  | e.g. localhost or postgres (Docker)
DB_PORT=5432                  # optional  | default: 5432
DB_USERNAME=                  # required
DB_PASSWORD=                  # required
DB_NAME=                      # required

# ── Backend ──────────────────────────────────────────────────
API_PORT=86                   # optional  | default: 86
USE_HTTPS=true                # optional  | set false in prod (proxy handles TLS)
FRONTEND_URL=https://localhost:3000  # optional  | used for CORS origin allowlist

# ── Frontend ─────────────────────────────────────────────────
VITE_API_URL=https://localhost:86  # optional in prod (nginx proxies /api)
                                   # required in dev Docker: https://localhost:86

# ── Email (Resend) ───────────────────────────────────────────
# Required for password reset emails. Without this the reset-password
# flow will fail. Get a key at https://resend.com.
RESEND_API_KEY=               # required for password reset

# ── Initial admin user (seeded on first startup if set) ───────
# ADMIN_NAME=                 # optional
# ADMIN_EMAIL=                # optional